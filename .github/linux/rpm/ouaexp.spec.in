%global appname ouaexp

# The bundle keeps its private libraries in /usr/lib/ouaexp on every architecture
# rather than in %%{_libdir}, which is what Firefox does and what the shared
# bundle.sh stages, so the layout is identical to the one the .deb ships.
%global appdir %{_prefix}/lib/%{appname}

# The binaries are stripped by bundle.sh and the Qt libraries come from the Qt
# installer, so there is nothing worth putting in a -debuginfo subpackage. The
# bundled OpenSSL is built from the source the Qt installer ships.
%global debug_package %{nil}
%global _build_id_links none

# The bundled Qt libraries are private: they must not satisfy the dependencies of
# any other package, and the sonames the bundle needs are resolved through the
# RPATH inside it rather than by the distribution. Anything outside the bundle -
# the C, C++, OpenGL and xcb runtimes - is left to the dependency generator.
%global __provides_exclude_from ^%{appdir}/.*$
%global __requires_exclude @REQUIRES_EXCLUDE@

Name:           @NAME@
Version:        @VERSION@
Release:        @RELEASE@
Summary:        OPC UA client for exploring and monitoring OPC UA servers

License:        MIT
URL:            https://github.com/sanny32/OpenUaExplorer

# The workflow builds an x86_64 bundle.
ExclusiveArch:  x86_64

# The icon is shipped into the hicolor theme, whose directories and cache trigger
# belong to hicolor-icon-theme.
Requires:       hicolor-icon-theme
Requires:       ca-certificates

# The session MIME type is registered by dropping its definition into
# /usr/share/mime/packages, which only takes effect once update-mime-database has
# run over it; the file trigger that does so ships with shared-mime-info.
Requires:       shared-mime-info

# The rpmbuild this is built with is the one Debian packages, and its dependency
# generator only reaches some of the staged files: the .rpm it produced asked for
# neither libstdc++ nor the fontconfig, freetype, EGL and xkbcommon the bundled Qt
# needs, and installing it left the program with unresolved symbols. The workflow
# reads what the bundle needs out of the bundle itself and writes it in here.
@REQUIRES@

%description
OpenUaExplorer is an open source OPC UA client for browsing, inspecting,
and monitoring OPC UA servers.

  * Browse the OPC UA address space and inspect node attributes.
  * View Data Access, subscriptions, events, and history panels.
  * Plot live and historical values on charts.
  * Connect anonymously, with a username, or with a client certificate.

# The tree was already built, bundled and staged by the workflow, so the only
# thing left to do is to hand it to rpmbuild.
%prep

%build

%install
cp -a %{_stagedir}/. %{buildroot}/

# The desktop database, the icon cache and the AppStream cache are all refreshed
# by the file triggers that ship with desktop-file-utils, gtk-update-icon-cache
# and appstream, so this package needs no scriptlets of its own.

%files
%dir %{_datadir}/licenses/%{name}
%license %{_datadir}/licenses/%{name}/LICENSE
%{_bindir}/%{appname}
%{appdir}/
%{_datadir}/applications/io.github.sanny32.OpenUaExplorer.desktop
%{_datadir}/icons/hicolor/scalable/apps/io.github.sanny32.OpenUaExplorer.svg
%{_datadir}/icons/hicolor/*x*/mimetypes/application-x-ouaexp-session.png
%{_datadir}/mime/packages/io.github.sanny32.OpenUaExplorer.xml
%{_datadir}/metainfo/io.github.sanny32.OpenUaExplorer.metainfo.xml

# The workflow appends the entry for the build it is producing.
%changelog
